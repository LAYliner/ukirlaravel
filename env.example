# ==========================================
# APLIKASI
# ==========================================
APP_NAME=ukirlaravel
APP_ENV=local
APP_DEBUG=true
APP_URL=
SESSION_DRIVER=file
CACHE_STORE=file
CACHE_DRIVER=file
QUEUE_CONNECTION=sync

# ==========================================
# DATABASE
# ==========================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ukiran
DB_USERNAME=example
DB_PASSWORD=example

# ==========================================
# KEAMANAN & AUTENTIKASI
# ==========================================
APP_KEY=example

# ==========================================
# LOGGING & MONITORING
# ==========================================
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ==========================================
# EMAIL (Development: log, Production: smtp)
# ==========================================
# Konfigurasi SMTP Brevo (aktifkan saat production):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=example
# MAIL_PASSWORD=example
# MAIL_ENCRYPTION=tls
